# config/template.env — schema for forking this repo to a new operator.
#
# Copy this to config/<env>.env (e.g. config/production.env) and fill in:
#
#   1. Identity values (WORKER_NAME, CF_SUBDOMAIN, etc.) — whatever you want.
#   2. Run `mise run cf:provision` — creates D1 + R2, writes IDs back here.
#   3. Run `mise run secrets:put-cf` — pulls the four CF Access secrets from
#      fnox and pushes them to the Worker as wrangler secrets.
#   4. Run `mise run 10-deploy`.
#
# Every mise task accepts `-- --env <env>` to switch which config file
# it reads. Default is `production`.
#
# DO NOT COMMIT a filled-out config/<env>.env. They're gitignored — keep
# real values out of git.

# ── Identity ─────────────────────────────────────────────────────────────────

# Cloudflare Worker name (must be unique in your CF account).
WORKER_NAME=d1-manager

# Your *.workers.dev subdomain (the part before .workers.dev).
CF_SUBDOMAIN=

# ── Cloudflare resources (set by `mise run cf:provision`) ────────────────────

# d1-manager's metadata D1 database.
METADATA_DB_NAME=d1-manager-metadata
METADATA_DB_ID=

# R2 bucket for hourly DB snapshots.
BACKUP_BUCKET_NAME=d1-manager-backups

# ── Cloudflare Access (set in dashboard, then `secrets:put-cf` pushes them) ──
#
# These four are NOT stored in this file — they live in fnox under the same
# names. They're listed here only so operators know what's required.
#
#   ACCOUNT_ID    — dash.cloudflare.com/<ACCOUNT_ID>/...
#   API_KEY       — Custom token: Account → D1 → Edit
#   TEAM_DOMAIN   — https://<your-team>.cloudflareaccess.com (https:// REQUIRED)
#   POLICY_AUD    — Access Application audience tag (Zero Trust dashboard)

# Subset of fnox keys that should also sync to GitHub Actions secrets
# (for any CI workflows that deploy from a PR). Leave empty if the
# fork does its deploys exclusively from a developer machine.
FNOX_SYNC_KEYS=

# ── Operator identity (used by cf:access:setup to gate the Access App) ───────

# Email allowed to access the d1-manager UI through CF Access. cf:access:setup
# adds an allow-by-email policy for this address. Multiple emails: comma-
# separate (no spaces). If empty, cf:access:setup creates the App with no
# policy — login will succeed at OAuth then 403 with no rule matching.
OPERATOR_EMAIL=
